use strict; use warnings;
use 5.028; use experimental 'signatures';

use Getopt::Long qw/:config bundling/;
use Hash::Util qw/ lock_keys /;
our $VERSION = '1.2.0';# Created: 2011-12-24

our %OPT = (  );
our @OPT_SPEC = qw/ help|h version path=s@ e class fonts|font|f /;
sub USAGE { <<"USAGE" };
usage: $_[0] [options] PATTERN
       $_[0] --class NAME

Search through unicode symbols for pattern. Eg:

\$ uni heart
0x2619  ☙  \\p{So}  REVERSED ROTATED FLORAL HEART BULLET
0x2661  ♡  \\p{So}  WHITE HEART SUIT
0x2665  ♥  \\p{So}  BLACK HEART SUIT
0x2763  ❣  \\p{So}  HEAVY HEART EXCLAMATION MARK ORNAMENT
...

\$ uni --class Po
0x0021  !  \\p{Po}  EXCLAMATION MARK
0x0022  "  \\p{Po}  QUOTATION MARK
0x0023  #  \\p{Po}  NUMBER SIGN
0x0025  %  \\p{Po}  PERCENT SIGN
...


OPTIONS

 -e                  treat pattern as a regular expression
 --fonts             list fonts containing each glyph
 --path <dir>        path to examine for UnicodeData.txt
USAGE

use Encode;
use Unicode::UCD qw/ charinfo charprop charprops_all /;
use open ':encoding(UTF-8)', ':std';
@ARGV = map decode("UTF-8", $_), @ARGV;

our %CATEGORY = (
    Cc => "Control",
    Cf => "Format",
    Co => "Private Use",
    Cs => "Surrrogate",
    Ll => "Lowercase Letter",
    Lm => "Modifier Letter",
    Lo => "Other Letter",
    Lt => "Titlecase Letter",
    Lu => "Uppercase Letter",
    Mc => "Spacing Mark",
    Me => "Enclosing Mark",
    Mn => "Nonspacing Mark",
    Nd => "Decimal Number",
    Nl => "Letter Number",
    No => "Other Number",
    Pc => "Connector Punctuation",
    Pd => "Dash Punctuation",
    Pe => "Close Punctuation",
    Pf => "Final Punctuation",
    Pi => "Initial Punctuation",
    Po => "Other Punctuation",
    Ps => "Open Punctuation",
    Sc => "Currency Symbol",
    Sk => "Modifier Symbol",
    Sm => "Math Symbol",
    So => "Other Symbol",
    Zl => "Line Separator",
    Zp => "Paragraph Separator",
    Zs => "Space Separator",
);

get_options( \%OPT, @OPT_SPEC );

# Process any single-char patterns first
while (@ARGV and length($ARGV[0]) == 1) {
    show_char(ord $ARGV[0]);
    shift @ARGV;
}

# if anything left, do a search
if (@ARGV) {
    search("@ARGV");
}

sub search($pat) {
    my $DATA;
    for (@{$OPT{path} || []}, "/usr/share/unicode", @INC) {
        next if ref;
        for my $fname ("$_/UnicodeData.txt", "$_/unicore/UnicodeData.txt") {
            if (-f $fname) {
                open $DATA, "<", $fname or die "Error reading $fname: $!";
                last;
            }
        }
    }
    die "Unable to locate unicore/UnicodeData.txt (do you need to install the unicode-data package?)" unless $DATA;

    if ($OPT{e})     { $pat = qr/$pat/i }
    if ($OPT{class}) { $pat = qr/;\Q$pat\E;/ }
    else             { $pat = qr/\Q$pat\E/i }

    while (my $line = <$DATA>) {
        next unless $line =~ $pat;
        my @F = split /;/, $line;
        show_char("0x$F[0]");
    }
}

sub show_char($codepoint) {
    my $info = charinfo($codepoint);
    return unless $$info{code};
    $$info{chr} = chr(hex($$info{code}));
    $$info{name} //= "Private Use";
    $$info{unicode10} = $$info{unicode10} ? "  Unicode 1.0 name: $$info{unicode10}" : "";
    my @props = props($codepoint);
    # push @props, "'$CATEGORY{$$info{category}}'" if $CATEGORY{$$info{category}};
    push @props, "Numeric" if $$info{category} =~ /^N[dlo]$/; # Rust .is_numeric()
    push @props, "Control" if $$info{category} eq 'Cc'; # Rust .is_control()
    $$info{props} = @props ? "  <@props>" : "";
    say "0x$$info{code}  $$info{chr}  \\p{$$info{category}}  $$info{name}$$info{unicode10}$$info{props}";
    if ($OPT{fonts}) {
        my @fonts = fonts($$info{code});
        if (@fonts > 20) { splice @fonts, 16; push @fonts, "..."; }
        say "   FONTS: ", join ", ", @fonts if @fonts;
    }
}

sub props($codepoint) {
    state %KEEP = map +($_, 1), (
        qw/ Alphabetic Lowercase Uppercase White_Space /, # Rust char .is_*() methods
    );
    my @keep;
    for my $prop (sort keys %KEEP) {
        my $value = charprop($codepoint, $prop);
        next unless $value;
        next if $value eq 'No';
        push @keep, $prop;
    }
#     my $props = charprops_all($codepoint);
#     for my $prop (sort keys %$props) {
#         next unless $$props{$prop};
#         next if $$props{$prop} eq 'No';
#         push @keep, $prop if $KEEP{$prop};
#     }
    return @keep
}

sub fonts($hex) {
    open my $fh, "-|", "fc-list", "-f", '%{family}\n', ":charset=$hex" or die;
    my %seen;
    while (defined(my $line = <$fh>)) {
        chomp($line);
        $seen{$line} = 1;
    }
    sort keys %seen;
}

sub get_options {
  my $OPT = shift;
  GetOptions $OPT, @_ or ($$OPT{help} = 1);
  usage() if $$OPT{help} || $$OPT{version};
  lock_keys(%$OPT, keys %$OPT, map /^(\w+)/, @_);
}

sub usage {
  print @_, "\n" if @_;
  require File::Spec; my $exe = (File::Spec->splitpath($0))[2];
  $OPT{$_} = $OPT{$_} ? "enabled" : "disabled" for map /^(\w+).*!/, @OPT_SPEC;
  print $OPT{version} ? "$exe version $VERSION\n" : USAGE($exe);
  exit;
}
